{
  "expo": {
    "name": "Lanieats for Merchants",
    "slug": "lani-merchants-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/lani_merchant_icon_512x512.png",
    "scheme": "lanimerchantsapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lanieats.merchants"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/lani_merchant_icon_512x512.png",
        "backgroundColor": "#FF6B00"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lanieats.merchants",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF6B00"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Lanieats to access your photos to upload restaurant images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/lani_merchant_icon_512x512.png",
          "color": "#FF6B00"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65ef47a6-0a02-4196-ba88-a360a79cc6b3"
      }
    },
    "owner": "jabulaniusen"
  }
}
